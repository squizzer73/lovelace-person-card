{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "strict": true,
    "declaration": false,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "tests/**/*"]
}
